from pathlib import Path
from database import AssetDatabase, Script


class ScriptManager:
    """剧本管理类"""
    
    def __init__(self, db_path: Path):
        self.db_path = db_path
        self.db = AssetDatabase(db_path)
        
    def add_script(self, title: str, logline: str, genre: str, tone: str, themes: list[str]):
        """添加剧本"""
        script_id = f"script_{len(self.db.get_scripts()) + 1}"
        script = Script(
            id=script_id,
            title=title,
            logline=logline,
            genre=genre,
            tone=tone,
            themes=themes
        )
        self.db.add_script(script)
        
    def save_script(self, path: Path):
        """保存剧本"""
        data = {
            "scripts": [s.to_dict() for s in self.db.get_scripts()]
        }
        with open(path, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
