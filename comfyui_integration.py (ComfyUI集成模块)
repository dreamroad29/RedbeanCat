RedbeanCat v2.0 - ComfyUI工作流集成模块
开发者：红豆猫工作室
支持：工作流导入/导出 + FLUX模型调用 + OpenAI API
"""
import json
from pathlib import Path
from typing import Dict, List, Optional
import requests


class ComfyUIWorkflow:
    """ComfyUI工作流管理类 v2.0"""
    
    def __init__(self, api_url: str = None):
        self.api_url = api_url  # 可选：ComfyUI API地址
        
    def load_workflow(self, json_path: Path) -> Dict:
        """导入ComfyUI工作流"""
        with open(json_path) as f:
            workflow = json.load(f)
        return workflow
        
    def export_workflow(self, workflow: Dict, output_path: Path):
        """导出ComfyUI工作流"""
        with open(output_path, 'w', encoding='utf-8') as f:
            json.dump(workflow, f, ensure_ascii=False, indent=2)
            
    def generate_flux_prompt(self, storyboard_id: str) -> str:
        """生成FLUX提示词"""
        from database import AssetDatabase
        db = AssetDatabase(Path("soulens_assets"))
        
        storyboards = db.get_storyboards()
        for sb in storyboards:
            if sb["id"] == storyboard_id:
                # 基础提示词
                base_prompt = f"anime style, {sb['action']}, " \
                             f"{sb.get('dialogue', '')}, " \
                             f"{sb.get('camera_angle', 'medium shot')}"
                
                # 添加角色特征
                characters = db.get_characters()
                for char in characters:
                    if char["name"] in sb.get("action", ""):
                        base_prompt += f", {char['hair_style']}, " \
                                      f"{', '.join(char['outfits'])}"
                  
                # 添加场景特征
                scenes = db.get_scenes()
                for scene in scenes:
                    if scene["name"] in sb.get("action", ""):
                        base_prompt += f", {scene['background']}, " \
                                      f"{scene['lighting']}"
                        
                return base_prompt
                
        return ""
        
    def call_flux_api(self, prompt: str, output_path: Path):
        """调用FLUX API生成图片"""
        if not self.api_url:
            print("⚠️ 未配置ComfyUI API地址")
            return
            
        response = requests.post(
            f"{self.api_url}/generate",
            json={
                "prompt": prompt,
                "width": 1024,
                "height": 1024,
                "steps": 20,
                "cfg_scale": 7.5
            }
        )
        
        if response.status_code == 200:
            result = response.json()
            with open(output_path, 'wb') as f:
                f.write(result["image"])
            print(f"✅ 图片已生成：{output_path}")
            
    def call_openai_api(self, prompt: str, output_path: Path, 
                       api_url: str = None, api_key: str = None):
        """调用OpenAI格式API生成图片"""
        if not api_url or not api_key:
            print("⚠️ 未配置OpenAI API地址或密钥")
            return
            
        headers = {
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json"
        }
        
        payload = {
            "model": "dall-e-3",
            "prompt": prompt,
            "size": "1024x1024",
            "n": 1,
            "response_format": "b64_json"
        }
        
        try:
            response = requests.post(
                api_url,
                headers=headers,
                json=payload
            )
            
            if response.status_code == 200:
                result = response.json()
                # 保存为PNG格式
                import base64
                image_data = base64.b64decode(result["data"][0]["b64"])
                with open(output_path, 'wb') as f:
                    f.write(image_data)
                print(f"✅ OpenAI图片已生成：{output_path}")
            else:
                print(f"❌ API调用失败：{response.text}")
                
        except Exception as e:
            print(f"❌ 错误：{str(e)}")
            
    def call_local_api(self, prompt: str, output_path: Path, 
                      api_url: str = "http://localhost:11434/api/generate"):
        """调用本地API (支持Ollama/LocalAI格式)"""
        headers = {
            "Content-Type": "application/json"
        }
        
        payload = {
            "model": "flux-dev",
            "prompt": prompt,
            "format": "png",
            "size": "1024x1024"
        }
        
        try:
            response = requests.post(
                api_url,
                headers=headers,
                json=payload
            )
            
            if response.status_code == 200:
                result = response.json()
                image_data = base64.b64decode(result.get("response", b""))
                with open(output_path, 'wb') as f:
                    f.write(image_data)
                print(f"✅ 本地API图片已生成：{output_path}")
            else:
                print(f"❌ API调用失败：{response.text}")
                
        except Exception as e:
            print(f"❌ 错误：{str(e)}")
