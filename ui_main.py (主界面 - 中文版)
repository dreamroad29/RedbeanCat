        if char_id and image_type and image_path:
            from character_lib import CharacterLibrary
            self.char_lib.save_character_image(char_id, image_type, image_path)
            QMessageBox.information(self, "成功", f"角色图片路径已保存")
            
    def save_scene_image(self):
        """保存场景图片路径"""
        scene_id = self.scene_table.item(self.scene_table.currentRow(), 0).text()
        image_type = self.scene_image_type_input.text().strip()
        image_path = self.scene_image_path_input.text().strip()
        
        if scene_id and image_type and image_path:
            from scene_lib import SceneLibrary
            self.scene_lib.save_scene_image(scene_id, image_type, image_path)
            QMessageBox.information(self, "成功", f"场景图片路径已保存")
            
    def export_production_pack(self):
        """导出漫剧制作包"""
        from batch_export import BatchExporter
        exporter = BatchExporter(self.db_path)
        
        output_dir, _ = QFileDialog.getSaveFileName(
            self, "导出漫剧制作包", "", "Production Pack (*.zip)"
        )
        
        if output_dir:
            # 创建临时目录
            temp_dir = Path(output_dir).parent / f"temp_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
            exporter.export_production_pack(temp_dir)
            
            # 压缩为ZIP (需安装zipfile)
            import zipfile
            with zipfile.ZipFile(output_dir, 'w', zipfile.ZIP_DEFLATED) as zipf:
                for file in temp_dir.rglob("*"):
                    if file.is_file():
                        zipf.write(file, arcname=file.relative_to(temp_dir))
                        
            # 清理临时目录
            import shutil
            shutil.rmtree(temp_dir)
            
            QMessageBox.information(self, "成功", f"漫剧制作包已导出到：{output_dir}")
            
    def generate_image(self):
        """生成图片"""
        from comfyui_integration import ComfyUIWorkflow
        
        # 获取当前选中的分镜
        row = self.storyboard_table.currentRow()
        if row < 0:
            QMessageBox.warning(self, "警告", "请选择一个分镜")
            return
            
        shot_id = self.storyboard_table.item(row, 0).text()
        
        # 生成提示词
        workflow = ComfyUIWorkflow(self.api_url)
        prompt = workflow.generate_flux_prompt(shot_id)
        
        if not prompt:
            QMessageBox.warning(self, "警告", "无法生成提示词")
            return
            
        # 保存提示词
        output_path = Path("generated_images") / f"{shot_id}.png"
        output_path.parent.mkdir(parents=True, exist_ok=True)
        
        # 调用API
        workflow.call_openai_api(prompt, output_path, self.api_url, self.api_key)


