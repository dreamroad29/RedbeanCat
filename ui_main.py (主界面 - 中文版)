    def add_script(self):
        """添加剧本"""
        title = self.script_title_input.text().strip()
        if not title:
            QMessageBox.warning(self, "警告", "请输入剧本标题")
            return
            
        logline = self.script_logline_input.text().strip()
        genre = self.script_genre_input.text().strip()
        tone = self.script_tone_input.text().strip()
        themes = [t.strip() for t in self.script_themes_input.text().split(",") if t.strip()]
        
        self.script_mgr.add_script(title, logline, genre, tone, themes)
        self.refresh_tables()
        
    def add_shot(self):
        """添加分镜"""
        script_id = self.shot_script_input.text().strip()
        scene_num = int(self.shot_scene_input.text().strip()) if self.shot_scene_input.text().strip() else 1
        shot_num = int(self.shot_shot_input.text().strip()) if self.shot_shot_input.text().strip() else 1
        duration = float(self.shot_duration_input.text().strip()) if self.shot_duration_input.text().strip() else 5.0
        
        if not script_id:
            QMessageBox.warning(self, "警告", "请输入关联剧本ID")
            return
            
        self.storyboard_mgr.add_storyboard(
            script_id=script_id,
            scene_number=scene_num,
            shot_number=shot_num,
            duration=duration,
            camera_angle=self.shot_angle_input.text().strip(),
            action=self.shot_action_input.text().strip(),
            dialogue=self.shot_dialogue_input.text().strip()
        )
        self.refresh_tables()
        
    def add_character(self):
        """添加角色"""
        name = self.char_name_input.text().strip()
        if not name:
            QMessageBox.warning(self, "警告", "请输入角色名称")
            return
            
        hair = self.char_hair_input.text().strip()
        outfits = [o.strip() for o in self.char_outfits_input.text().split(",") if o.strip()]
        expressions = [e.strip() for e in self.char_expressions_input.text().split(",") if e.strip()]
        
        self.char_lib.add_character(name, hair, outfits, expressions)
        self.refresh_tables()
        
    def add_scene(self):
        """添加场景"""
        name = self.scene_name_input.text().strip()
        if not name:
            QMessageBox.warning(self, "警告", "请输入场景名称")
            return
            
        bg = self.scene_bg_input.text().strip()
        lighting = self.scene_lighting_input.text().strip()
        props = [p.strip() for p in self.scene_props_input.text().split(",") if p.strip()]
        
        self.scene_lib.add_scene(name, bg, lighting, props)
        self.refresh_tables()
        
    def refresh_tables(self):
        """刷新所有表格"""
        # 刷新剧本表格
        self.script_table.setRowCount(0)
        for script in self.script_mgr.db.get_scripts():
            row = self.script_table.rowCount()
            self.script_table.insertRow(row)
            self.script_table.setItem(row, 0, QTableWidgetItem(script["id"]))
            self.script_table.setItem(row, 1, QTableWidgetItem(script["title"]))
            self.script_table.setItem(row, 2, QTableWidgetItem(script["logline"]))
            self.script_table.setItem(row, 3, QTableWidgetItem(script.get("genre", "")))
            self.script_table.setItem(row, 4, QTableWidgetItem(script.get("tone", "")))
            
        # 刷新分镜表格
        self.storyboard_table.setRowCount(0)
        for sb in self.storyboard_mgr.db.get_storyboards():
            row = self.storyboard_table.rowCount()
            self.storyboard_table.insertRow(row)
            self.storyboard_table.setItem(row, 0, QTableWidgetItem(sb["id"]))
            self.storyboard_table.setItem(row, 1, QTableWidgetItem(f"场景{sb['scene_number']}"))
            self.storyboard_table.setItem(row, 2, QTableWidgetItem(str(sb["shot_number"])))
            self.storyboard_table.setItem(row, 3, QTableWidgetItem(str(sb["duration"])))
            self.storyboard_table.setItem(row, 4, QTableWidgetItem(sb.get("camera_angle", "")))
            self.storyboard_table.setItem(row, 5, QTableWidgetItem(sb.get("action", "")))
            self.storyboard_table.setItem(row, 6, QTableWidgetItem(sb.get("dialogue", "")))
            self.storyboard_table.setItem(row, 7, QTableWidgetItem(sb.get("notes", "")))
            
        # 刷新角色表格
        self.char_table.setRowCount(0)
        for char in self.char_lib.db.get_characters():
            row = self.char_table.rowCount()
            self.char_table.insertRow(row)
            self.char_table.setItem(row, 0, QTableWidgetItem(char["id"]))
            self.char_table.setItem(row, 1, QTableWidgetItem(char["name"]))
            self.char_table.setItem(row, 2, QTableWidgetItem(char["hair_style"]))
            self.char_table.setItem(row, 3, QTableWidgetItem(", ".join(char.get("outfits", []))))
            self.char_table.setItem(row, 4, QTableWidgetItem(", ".join(char.get("expressions", []))))
            
        # 刷新场景表格
        self.scene_table.setRowCount(0)
        for scene in self.scene_lib.db.get_scenes():
            row = self.scene_table.rowCount()
            self.scene_table.insertRow(row)
            self.scene_table.setItem(row, 0, QTableWidgetItem(scene["id"]))
            self.scene_table.setItem(row, 1, QTableWidgetItem(scene["name"]))
            self.scene_table.setItem(row, 2, QTableWidgetItem(scene["background"]))
            self.scene_table.setItem(row, 3, QTableWidgetItem(scene["lighting"]))
            self.scene_table.setItem(row, 4, QTableWidgetItem(", ".join(scene.get("props", []))))
            
