from pathlib import Path
import zipfile
import shutil


class BatchExporter:
    """批量导出器"""
    
    def __init__(self, db_path: Path):
        self.db_path = db_path
        
    def export_production_pack(self, output_dir: Path):
        """导出漫剧制作包"""
        # 创建临时目录
        temp_dir = Path(output_dir).parent / f"temp_{output_dir.name}"
        
        # 复制数据库文件
        assets_json = self.db_path / "assets.json"
        if assets_json.exists():
            shutil.copy(assets_json, temp_dir)
            
        # 复制脚本文件
        for py_file in Path(__file__).parent.glob("*.py"):
            if py_file.name not in ["__init__.py", "batch_export.py"]:
                shutil.copy(py_file, temp_dir)
                
        # 创建README
        readme_path = temp_dir / "README.md"
        readme_content = """# RedbeanCat v2.0 - 漫剧制作包

## 📦 使用说明

1. 运行 `python main.py` 启动程序
2. 导入项目数据 (assets.json)
3. 开始创作漫剧

## 🎯 功能清单

- ✅ 剧本管理 (Save the Cat结构)
- ✅ 分镜管理 (镜头编号/时长/角度)
- ✅ 角色库 (发型/服装/表情)
- ✅ 场景库 (背景/灯光/道具)
- ✅ OpenAI API调用
- ✅ 本地API接入

## 📞 联系方式

红豆猫工作室
"""
        readme_path.write_text(readme_content, encoding='utf-8')
        
        # 压缩为ZIP
        zip_path = output_dir / "RedbeanCat_Production_Pack.zip"
        with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for file in temp_dir.rglob("*"):
                if file.is_file():
                    zipf.write(file, arcname=file.relative_to(temp_dir))
                    
        # 清理临时目录
        shutil.rmtree(temp_dir)
        
        return zip_path
