"""
RedbeanCat v2.0 - 数据库管理模块
开发者：红豆猫工作室
支持 SQLite + JSON双模式存储 + 图片路径管理
"""
import json
from pathlib import Path
from typing import Optional, List, Dict, Any
from dataclasses import dataclass, asdict


@dataclass
class Script:
    """剧本数据模型 - Save the Cat结构"""
    id: str
    title: str
    logline: str
    genre: str
    tone: str
    themes: list[str] = None
    
    def to_dict(self):
        return asdict(self)


@dataclass  
class Storyboard:
    """分镜数据模型"""
    id: str
    script_id: str
    scene_number: int
    shot_number: int
    duration: float
    camera_angle: str
    action: str
    dialogue: str = ""
    notes: str = None
    image_path: str = None
    
    def to_dict(self):
        return asdict(self)


@dataclass
class Character:
    """角色数据模型"""
    id: str
    name: str
    hair_style: str
    outfits: list[str]
    expressions: list[str]
    images: dict[str, str] = None
    
    def to_dict(self):
        return asdict(self)


@dataclass  
class Scene:
    """场景数据模型"""
    id: str
    name: str
    background: str
    lighting: str
    props: list[str]
    images: dict[str, str] = None
    
    def to_dict(self):
        return asdict(self)


class AssetDatabase:
    """资产数据库管理类 v2.0"""
    
    def __init__(self, db_path: Path):
        self.db_path = db_path
        self.json_db = db_path / "assets.json"
        
    def init_database(self):
        """初始化数据库"""
        if not self.json_db.exists():
            default_data = {
                "scripts": [],
                "storyboards": [],
                "characters": [],
                "scenes": []
            }
            self.json_db.write_text(json.dumps(default_data, ensure_ascii=False, indent=2))
            
    def save_json(self):
        """保存JSON数据库"""
        data = {
            "scripts": [s.to_dict() for s in self.get_scripts()],
            "storyboards": [sb.to_dict() for sb in self.get_storyboards()],
            "characters": [c.to_dict() for c in self.get_characters()],
            "scenes": [sc.to_dict() for sc in self.get_scenes()]
        }
        with open(self.json_db, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
            
    def add_script(self, script: Script):
        """添加剧本"""
        data = self.get_all_data()
        data["scripts"].append(script.to_dict())
        self.save_json()
        
    def add_storyboard(self, storyboard: Storyboard):
        """添加分镜"""
        data = self.get_all_data()
        data["storyboards"].append(storyboard.to_dict())
        self.save_json()
        
    def add_character(self, char: Character):
        """添加角色"""
        data = self.get_all_data()
        data["characters"].append(char.to_dict())
        self.save_json()
        
    def add_scene(self, scene: Scene):
        """添加场景"""
        data = self.get_all_data()
        data["scenes"].append(scene.to_dict())
        self.save_json()
        
    def get_scripts(self) -> List[Dict]:
        """获取所有剧本"""
        return self.get_all_data().get("scripts", [])
        
    def get_storyboards(self) -> List[Dict]:
        """获取所有分镜"""
        return self.get_all_data().get("storyboards", [])
        
    def get_characters(self) -> List[Dict]:
        """获取所有角色"""
        return self.get_all_data().get("characters", [])
        
    def get_scenes(self) -> List[Dict]:
        """获取所有场景"""
        return self.get_all_data().get("scenes", [])
        
    def get_all_data(self) -> Dict[str, Any]:
        """获取所有数据"""
        if self.json_db.exists():
            return json.loads(self.json_db.read_text(encoding='utf-8'))
        return {"scripts": [], "storyboards": [], "characters": [], "scenes": []}
        
    def get_character_images(self, char_id: str) -> Dict[str, str]:
        """获取角色图片路径"""
        for char in self.get_characters():
            if char["id"] == char_id:
                return char.get("images", {})
        return {}
        
    def get_scene_images(self, scene_id: str) -> Dict[str, str]:
        """获取场景图片路径"""
        for scene in self.get_scenes():
            if scene["id"] == scene_id:
                return scene.get("images", {})
        return {}
